<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TileTextureGenerator.Frontend.UI.ViewModels"
             xmlns:controls="clr-namespace:TileTextureGenerator.Frontend.UI.Controls"
             x:Class="TileTextureGenerator.Frontend.UI.Views.FlatHorizontalTransformationConfigView"
             x:DataType="vm:FlatHorizontalTransformationConfigViewModel"
             Title="Configure Flat Horizontal">
    
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">
            
            <!-- Title -->
            <Label Text="Flat Horizontal Transformation Configuration"
                   FontSize="24"
                   FontAttributes="Bold"/>
            
            <!-- Edge Flaps Configuration -->
            <Label Text="Edge Flaps Configuration"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,10,0,5"/>
            
            <!-- North -->
            <controls:EdgeFlapConfigControl x:Name="NorthConfig"/>
            
            <!-- South -->
            <controls:EdgeFlapConfigControl x:Name="SouthConfig"/>
            
            <!-- East -->
            <controls:EdgeFlapConfigControl x:Name="EastConfig"/>
            
            <!-- West -->
            <controls:EdgeFlapConfigControl x:Name="WestConfig"/>
            
            <!-- Action buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,20,0,0">
                <Button Grid.Column="0"
                        Text="Save"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource Primary}"/>
                <Button Grid.Column="1"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="{StaticResource Gray300}"/>
            </Grid>
            
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>
