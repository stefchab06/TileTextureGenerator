<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TileTextureGenerator.Frontend.UI.ViewModels"
             xmlns:enums="clr-namespace:TileTextureGenerator.Core.Enums;assembly=TileTextureGenerator.Core"
             xmlns:converters="clr-namespace:TileTextureGenerator.Frontend.UI.Converters"
             xmlns:controls="clr-namespace:TileTextureGenerator.Frontend.UI.Controls"
             x:Class="TileTextureGenerator.Frontend.UI.Views.SingleTileTextureInitializationView"
             Title="Initialisation de l'image">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:TileShapeToBorderConverter x:Key="TileShapeToBorderConverter" />
            <converters:IsNullConverter x:Key="IsNullConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:ZoomToScaleConverter x:Key="ZoomToScaleConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="10">

        <!-- Row 0: Image Acquisition Buttons -->
        <HorizontalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center" Margin="0,0,0,20">
            <Button Text="Charger" 
                    Command="{Binding LoadImageCommand}"
                    WidthRequest="120"/>
            <Button Text="Coller" 
                    Command="{Binding PasteImageCommand}"
                    IsEnabled="{Binding CanPaste}"
                    WidthRequest="120"/>
            <Button Text="Numériser" 
                    Command="{Binding ScanImageCommand}"
                    IsEnabled="{Binding CanScan}"
                    WidthRequest="120"/>
        </HorizontalStackLayout>

        <!-- Row 1: Tile Shape Selection -->
        <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="0,0,0,20">
            <Label Text="Forme de la tuile" 
                   FontSize="16" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                <!-- Full (Square) -->
                <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}"
                        StrokeThickness="2"
                        Stroke="{Binding SelectedTileShape, Converter={StaticResource TileShapeToBorderConverter}, ConverterParameter={x:Static enums:TileShape.Full}}"
                        Padding="10">
                    <Frame WidthRequest="60" 
                           HeightRequest="60" 
                           BackgroundColor="Black"
                           CornerRadius="5">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectTileShapeCommand}" 
                                                 CommandParameter="{x:Static enums:TileShape.Full}"/>
                        </Frame.GestureRecognizers>
                    </Frame>
                </Border>

                <!-- HalfHorizontal (Wide Rectangle) -->
                <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}"
                        StrokeThickness="2"
                        Stroke="{Binding SelectedTileShape, Converter={StaticResource TileShapeToBorderConverter}, ConverterParameter={x:Static enums:TileShape.HalfHorizontal}}"
                        Padding="10">
                    <Frame WidthRequest="80" 
                           HeightRequest="40" 
                           BackgroundColor="Black"
                           CornerRadius="5">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectTileShapeCommand}" 
                                                 CommandParameter="{x:Static enums:TileShape.HalfHorizontal}"/>
                        </Frame.GestureRecognizers>
                    </Frame>
                </Border>

                <!-- HalfVertical (Tall Rectangle) -->
                <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}"
                        StrokeThickness="2"
                        Stroke="{Binding SelectedTileShape, Converter={StaticResource TileShapeToBorderConverter}, ConverterParameter={x:Static enums:TileShape.HalfVertical}}"
                        Padding="10">
                    <Frame WidthRequest="40" 
                           HeightRequest="80" 
                           BackgroundColor="Black"
                           CornerRadius="5">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectTileShapeCommand}" 
                                                 CommandParameter="{x:Static enums:TileShape.HalfVertical}"/>
                        </Frame.GestureRecognizers>
                    </Frame>
                </Border>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Row 2: Image Work Area -->
        <Grid Grid.Row="2" Margin="0,0,0,20" x:Name="WorkArea">

            <!-- Landscape: Full width image -->
            <Grid x:Name="LandscapeLayout" IsVisible="False">
                <!-- Image Canvas -->
                <Border BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}"
                        Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444444}"
                        StrokeThickness="1">
                    <controls:ImageCropCanvasView 
                        ImageData="{Binding CurrentImage}"
                        TileShape="{Binding SelectedTileShape}"
                        ImageTranslationX="{Binding TranslationX}"
                        ImageTranslationY="{Binding TranslationY}"
                        RotationAngle="{Binding RotationAngle}"
                        ZoomLevel="{Binding ZoomLevel}"
                        ScaleX="{Binding ScaleX}"
                        ScaleY="{Binding ScaleY}"
                        IsSnapEnabled="{Binding IsSnapEnabled}"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                </Border>
            </Grid>

            <!-- Portrait: Full height image -->
            <Grid x:Name="PortraitLayout" IsVisible="False">
                <!-- Image Canvas -->
                <Border BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}"
                        Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444444}"
                        StrokeThickness="1">
                    <controls:ImageCropCanvasView 
                        ImageData="{Binding CurrentImage}"
                        TileShape="{Binding SelectedTileShape}"
                        ImageTranslationX="{Binding TranslationX}"
                        ImageTranslationY="{Binding TranslationY}"
                        RotationAngle="{Binding RotationAngle}"
                        ZoomLevel="{Binding ZoomLevel}"
                        ScaleX="{Binding ScaleX}"
                        ScaleY="{Binding ScaleY}"
                        IsSnapEnabled="{Binding IsSnapEnabled}"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                </Border>
            </Grid>

        </Grid>

        <!-- Row 3: Validate Button -->
        <Button Grid.Row="3"
                Text="Valider"
                Command="{Binding ValidateCommand}"
                HorizontalOptions="Center"
                WidthRequest="200"
                HeightRequest="50"
                FontSize="18"
                FontAttributes="Bold"/>
    </Grid>
</ContentPage>
