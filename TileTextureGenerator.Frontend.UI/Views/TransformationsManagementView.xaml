<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TileTextureGenerator.Frontend.UI.ViewModels"
             x:Class="TileTextureGenerator.Frontend.UI.Views.TransformationsManagementView"
             x:DataType="vm:TransformationsManagementViewModel"
             Title="Transformations Management">
    
    <Grid RowDefinitions="Auto,*" Padding="20">
        
        <!-- Header -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                Background="{StaticResource Gray100}"
                Padding="15"
                Margin="0,0,0,10">
            <Grid ColumnDefinitions="*,Auto">
                
                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Label Text="Type:" FontSize="16" VerticalOptions="Center"/>
                    
                    <Picker ItemsSource="{Binding AvailableTypes}"
                            SelectedItem="{Binding SelectedType}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            WidthRequest="200"
                            VerticalOptions="Center"/>
                </HorizontalStackLayout>
                
                <Button Grid.Column="1"
                        Text="Create"
                        Command="{Binding CreateTransformationCommand}"
                        HorizontalOptions="End"/>
            </Grid>
        </Border>
        
        <!-- List -->
        <ScrollView Grid.Row="1">
            <CollectionView ItemsSource="{Binding Transformations}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TransformationItemViewModel">
                        <Border Margin="5" Padding="10">
                            <Label Text="{Binding DisplayName}"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
        
    </Grid>
    
</ContentPage>
