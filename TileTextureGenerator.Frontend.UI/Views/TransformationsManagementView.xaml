<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TileTextureGenerator.Frontend.UI.ViewModels"
             xmlns:converters="clr-namespace:TileTextureGenerator.Frontend.UI.Converters"
             x:Class="TileTextureGenerator.Frontend.UI.Views.TransformationsManagementView"
             x:DataType="vm:TransformationsManagementViewModel"
             Title="Transformations Management">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsNullConverter x:Key="IsNullConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Title -->
            <Label Text="Texture Transformations"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Create new transformation section -->
            <Frame Padding="16" 
                   HasShadow="True"
                   CornerRadius="8"
                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Create New Transformation"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Picker Grid.Column="0"
                                ItemsSource="{Binding AvailableTypes}"
                                SelectedItem="{Binding SelectedType}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                Title="Select transformation type..." />

                        <Button Grid.Column="1"
                                Text="➕ Create"
                                Command="{Binding CreateTransformationCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                WidthRequest="120" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Existing transformations grid -->
            <Label Text="Configured Transformations"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,12,0,0" />

            <CollectionView ItemsSource="{Binding Transformations}"
                            SelectionMode="None"
                            x:Name="TransformationsCollection">

                <!-- Grid layout with responsive column count -->
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="1"
                                     HorizontalItemSpacing="12"
                                     VerticalItemSpacing="12"
                                     x:Name="TransformationsGridLayout" />
                </CollectionView.ItemsLayout>

                <!-- Visual States for responsive design -->
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <!-- Mobile/Narrow: 1 column -->
                        <VisualState x:Name="Narrow">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter TargetName="TransformationsGridLayout" Property="GridItemsLayout.Span" Value="1" />
                            </VisualState.Setters>
                        </VisualState>

                        <!-- Tablet/Medium: 2 columns -->
                        <VisualState x:Name="Medium">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="800" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter TargetName="TransformationsGridLayout" Property="GridItemsLayout.Span" Value="2" />
                            </VisualState.Setters>
                        </VisualState>

                        <!-- Desktop/Wide: 3 columns -->
                        <VisualState x:Name="Wide">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="1200" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter TargetName="TransformationsGridLayout" Property="GridItemsLayout.Span" Value="3" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <!-- Transformation card template -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TransformationItemViewModel">
                        <Frame Padding="16"
                               HasShadow="True"
                               CornerRadius="8"
                               BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="180" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header: Type and Name -->
                                <Label Grid.Row="0"
                                       Text="{Binding DisplayName}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Center" />

                                <!-- Generated image or placeholder -->
                                <Border Grid.Row="1"
                                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                                        StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}">
                                    <Grid>
                                        <!-- Actual image if generated -->
                                        <Image Source="{Binding GeneratedImage, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                               Aspect="AspectFit"
                                               IsVisible="{Binding GeneratedImage, Converter={StaticResource IsNotNullConverter}}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />

                                        <!-- Placeholder when not generated -->
                                        <VerticalStackLayout HorizontalOptions="Center"
                                                             VerticalOptions="Center"
                                                             Spacing="8"
                                                             IsVisible="{Binding GeneratedImage, Converter={StaticResource IsNullConverter}}">
                                            <Label Text="🖼️"
                                                   FontSize="64"
                                                   Opacity="0.3"
                                                   HorizontalOptions="Center" />
                                            <Label Text="Not generated yet"
                                                   FontSize="14"
                                                   Opacity="0.5"
                                                   HorizontalOptions="Center" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>

                                <!-- Action buttons (bottom right) -->
                                <HorizontalStackLayout Grid.Row="2"
                                                       HorizontalOptions="End"
                                                       Spacing="8">
                                    <!-- Edit button -->
                                    <Button Text="⚙️"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TransformationsManagementViewModel}}, Path=EditTransformationCommand}"
                                            CommandParameter="{Binding .}"
                                            ToolTipProperties.Text="Edit transformation"
                                            WidthRequest="50"
                                            HeightRequest="50"
                                            CornerRadius="25"
                                            BackgroundColor="{AppThemeBinding Light=#4CAF50, Dark=#66BB6A}" />

                                    <!-- Generate button -->
                                    <Button Text="▶️"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TransformationsManagementViewModel}}, Path=GenerateTransformationCommand}"
                                            CommandParameter="{Binding .}"
                                            ToolTipProperties.Text="Generate image"
                                            WidthRequest="50"
                                            HeightRequest="50"
                                            CornerRadius="25"
                                            BackgroundColor="{AppThemeBinding Light=#2196F3, Dark=#42A5F5}" />

                                    <!-- Delete button -->
                                    <Button Text="🗑️"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TransformationsManagementViewModel}}, Path=DeleteTransformationCommand}"
                                            CommandParameter="{Binding .}"
                                            ToolTipProperties.Text="Delete transformation"
                                            WidthRequest="50"
                                            HeightRequest="50"
                                            CornerRadius="25"
                                            BackgroundColor="{AppThemeBinding Light=#F44336, Dark=#EF5350}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
