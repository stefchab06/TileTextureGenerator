@startuml TileTextureGenerator - Domain Entities

!define ENTITY_COLOR #E1F5FE
!define REGISTRY_COLOR #FFF9C4
!define INTERFACE_COLOR #E8F5E9

title TileTextureGenerator - Domain Entities

package "Core.Entities" ENTITY_COLOR {
    
    abstract class ProjectBase {
        # IProjectStore _store
        --
        + string Name {get; private set}
        + string Type {get}
        + ProjectStatus Status {get; set}
        + DateTime LastModifiedDate {get; set}
        + ImageData? DisplayImage {get; set}
        + List<TransformationDTO> Transformations {get}
        + ProjectActions AvailableActions {get}
        --
        + void Initialize(string name)
        + Task SaveChangesAsync()
        + Task AddTransformationAsync(string type)
        + Task RemoveTransformationAsync(Guid id)
        + Task<TransformationBase> GetTransformationAsync(Guid id)
        + Task<bool> GenerateAsync()
        + Task<bool> ArchiveAsync()
        + {abstract} Task<IReadOnlyList<TransformationTypeDTO>> GetAvailableTransformationTypesAsync()
    }
    
    class FloorTileProject {
        - {static} string[] AvailableTransformationTypes
        --
        + ImageData? SourceImage {get; set}
        + TileShape TileShape {get; set}
        --
        + {static} FloorTileProject()
        + FloorTileProject(IProjectStore store)
        + Task<IReadOnlyList<TransformationTypeDTO>> GetAvailableTransformationTypesAsync()
    }
    
    class WallTileProject {
        - {static} string[] AvailableTransformationTypes
        --
        + ImageData? SourceImage {get; set}
        + TileShape TileShape {get; set}
        --
        + {static} WallTileProject()
        + WallTileProject(IProjectStore store)
        + Task<IReadOnlyList<TransformationTypeDTO>> GetAvailableTransformationTypesAsync()
    }
    
    abstract class TransformationBase {
        # ITransformationStore _store
        --
        + Guid Id {get; private set}
        + string Type {get}
        + ImageData? GeneratedTexture {get; set}
        + ProjectBase ParentProject {get; private set}
        + EdgeFlapConfiguration this[ImageSide] {get; set}
        + PaperType RequiredPaperType {get; set}
        --
        + void Initialize(ProjectBase parent, Guid id)
        + Task SaveChangesAsync()
        + Task<ImageData> GenerateAsync()
        # {abstract} Task<ImageData> ExecuteAsync()
    }
    
    interface ITransformationMetadata {
        + {static} string IconResourceName {get}
    }
    
    class HorizontalFloorTransformation {
        - const double FlapHeightInInches
        - const double MaxTileDimensionInInches
        --
        + ImageData? BaseTexture {get; set}
        + TileShape TileShape {get; set}
        + {static} string IconResourceName => "HorizontalFloor.png"
        --
        + {static} HorizontalFloorTransformation()
        + HorizontalFloorTransformation(ITransformationStore store)
        # Task<ImageData> ExecuteAsync()
        - void DrawFlap(...)
        - void DrawBlankFlap(...)
        - void DrawColorFlap(...)
        - void DrawTextureFlap(...)
        - void DrawSymmetricFlap(...)
    }
    
    class VerticalWallTransformation {
        - const double FlapHeightInInches
        - const double MaxTileDimensionInInches
        --
        + ImageData? BaseTexture {get; set}
        + TileShape TileShape {get; set}
        + {static} string IconResourceName => "VerticalWall.png"
        --
        + {static} VerticalWallTransformation()
        + VerticalWallTransformation(ITransformationStore store)
        # Task<ImageData> ExecuteAsync()
        - void DrawFlap(...)
        - void DrawBlankFlap(...)
        - void DrawColorFlap(...)
        - void DrawTextureFlap(...)
        - void DrawSymmetricFlap(...)
    }
}

package "Core.Registries" REGISTRY_COLOR {
    class TextureProjectRegistry <<static>> {
        - {static} Dictionary<string, Type> _types
        - {static} Func<Type, ProjectBase>? _factory
        --
        + {static} void SetFactory(Func<Type, ProjectBase> factory)
        + {static} void RegisterType<TProject>()
        + {static} ProjectBase Create(string key, string name)
        + {static} IReadOnlyCollection<string> GetAllTypeNames()
        + {static} void RegisterAll()
    }
    
    class TransformationTypeRegistry <<static>> {
        - {static} Dictionary<string, Type> _types
        - {static} Func<Type, TransformationBase>? _factory
        --
        + {static} void SetFactory(Func<Type, TransformationBase> factory)
        + {static} void Register<T>()
        + {static} TransformationBase Create(string typeName, ProjectBase parent)
        + {static} IReadOnlyCollection<Type> GetAllTypes()
        + {static} Type? GetTypeByName(string typeName)
        + {static} bool IsRegistered(string typeName)
        + {static} ImageData? GetIcon(string typeName)
        + {static} void RegisterAll()
        + {static} void ForceAutoRegistrationFromCore()
    }
}

package "Core.Models" {
    struct ImageData {
        + byte[] Bytes
    }
    
    struct EdgeFlapConfiguration {
        + EdgeFlapMode Mode
        + string? Color
        + ImageData? Texture
    }
}

package "Core.Enums" {
    enum ProjectStatus {
        Unexisting
        New
        Pending
        Generated
        Archived
    }
    
    enum TileShape {
        Full
        HalfHorizontal
        HalfVertical
    }
    
    enum ImageSide {
        Top = 0
        Right = 1
        Bottom = 2
        Left = 3
    }
    
    enum EdgeFlapMode {
        None
        Blank
        Color
        Texture
        Symmetric
    }
    
    enum PaperType {
        Standard
        Heavy
    }
    
    enum ProjectActions {
        None = 0
        Load = 1
        Generate = 2
        Archive = 4
        Delete = 8
    }
}

' Inheritance relationships
ProjectBase <|-- FloorTileProject
ProjectBase <|-- WallTileProject
TransformationBase <|-- HorizontalFloorTransformation
TransformationBase <|-- VerticalWallTransformation
TransformationBase ..|> ITransformationMetadata : implements

' Registry relationships
TextureProjectRegistry ..> ProjectBase : creates via\nfactory pattern
TransformationTypeRegistry ..> TransformationBase : creates via\nfactory pattern
TransformationTypeRegistry ..> ITransformationMetadata : uses for\nicon loading

' Entity relationships
ProjectBase o-- TransformationDTO : contains list
TransformationBase --> EdgeFlapConfiguration : has 4 (indexed)
TransformationBase --> ProjectBase : references parent
ProjectBase --> ImageData : DisplayImage
FloorTileProject --> ImageData : SourceImage
WallTileProject --> ImageData : SourceImage
HorizontalFloorTransformation --> ImageData : BaseTexture, GeneratedTexture
VerticalWallTransformation --> ImageData : BaseTexture, GeneratedTexture

' Enum usages
ProjectBase --> ProjectStatus
ProjectBase --> ProjectActions
FloorTileProject --> TileShape
WallTileProject --> TileShape
HorizontalFloorTransformation --> TileShape
VerticalWallTransformation --> TileShape
EdgeFlapConfiguration --> EdgeFlapMode
TransformationBase --> PaperType
EdgeFlapConfiguration --> ImageSide : indexed by

note right of ProjectBase
  **Initialize-after-construction pattern**
  1. Constructor: DI only
  2. Initialize(name): Runtime data + validation
  3. Name becomes immutable after Initialize
end note

note right of TransformationBase
  **Initialize-after-construction pattern**
  1. Constructor: DI only
  2. Initialize(parent, id): Runtime data
  3. Id becomes immutable after Initialize
end note

note bottom of TextureProjectRegistry
  **Factory pattern with DI injection**
  - Factory function injected at startup
  - Static constructors register types
  - Create() uses factory + Initialize()
end note

note bottom of TransformationTypeRegistry
  **Factory pattern + Icon management**
  - Uses reflection to get static IconResourceName
  - Loads icons from embedded resources
  - Supports duplicate registration (idempotent)
end note

@enduml
