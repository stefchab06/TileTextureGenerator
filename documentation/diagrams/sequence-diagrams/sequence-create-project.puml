@startuml Create Project - Sequence Diagram

title Create Project Use Case - Complete Flow

actor User
participant "ManageProjectList\nPage" as UI
participant "ManageProjectList\nViewModel" as ViewModel
participant "ManageProjectList\nUseCase" as UseCase
participant "IProjectsManager\n(Port Input)" as ManagerPort
participant "ProjectsManager\n(Service)" as Manager
participant "TextureProject\nRegistry" as Registry
participant "ProjectBase\n(Entity)" as Project
participant "IProjectsStore\n(Port Output)" as StorePort
participant "JsonProjectsStore\n(Adapter)" as Store
participant "FileSystem\nService" as FileSystem

User -> UI : Click "Create Project"
activate UI
UI -> UI : Show create dialog
User -> UI : Enter name + select type
UI -> ViewModel : CreateProjectAsync(name, type)
activate ViewModel

ViewModel -> UseCase : CreateProjectAsync(name, type)
activate UseCase

' Validation
UseCase -> UseCase : Validate name & type
alt Validation fails
    UseCase --> ViewModel : CreateProjectResult.ValidationError
    ViewModel --> UI : Show error message
    UI --> User : Display error
else Validation succeeds
    
    ' Create project
    UseCase -> ManagerPort : CreateProjectAsync(name, type)
    activate ManagerPort
    ManagerPort -> Manager : CreateProjectAsync(name, type)
    activate Manager
    
    Manager -> Manager : Validate project doesn't exist
    Manager -> Registry : Create(type, name)
    activate Registry
    
    Registry -> Registry : Get Type from _types[type]
    Registry -> Registry : _factory(Type)
    create Project
    Registry -> Project : new (via DI factory)
    Registry -> Project : Initialize(name)
    activate Project
    Project -> Project : Set Name (immutable)
    Project -> Project : Set Type
    Project -> Project : Set Status = New
    Project -> Project : Set LastModifiedDate
    Project -> Project : Calculate AvailableActions
    deactivate Project
    
    Registry --> Manager : ProjectBase instance
    deactivate Registry
    
    Manager -> StorePort : SaveAsync(project)
    activate StorePort
    StorePort -> Store : SaveAsync(project)
    activate Store
    
    Store -> Store : Create project directory\n(clean name)
    Store -> FileSystem : CreateDirectory(path)
    Store -> Store : Serialize project to JSON\n(base properties only)
    Store -> FileSystem : WriteAllTextAsync(project.json)
    
    alt DisplayImage exists
        Store -> Store : Save DisplayImage
        Store -> FileSystem : WriteAllBytesAsync(images/guid.png)
    end
    
    Store --> StorePort : success
    deactivate Store
    StorePort --> Manager : success
    deactivate StorePort
    
    Manager --> ManagerPort : ProjectBase
    deactivate Manager
    ManagerPort --> UseCase : ProjectBase
    deactivate ManagerPort
    
    ' Create EditProjectUseCase
    UseCase -> UseCase : new EditProjectUseCase(project)
    UseCase --> ViewModel : CreateProjectResult.Success\n(project, editUseCase)
    deactivate UseCase
    
    ' Navigate to EditProjectPage
    ViewModel -> ViewModel : new EditProjectViewModel(editUseCase)
    ViewModel -> UI : Shell.GoToAsync("EditProjectPage",\nviewModel)
    deactivate ViewModel
    
    UI -> UI : Navigate to EditProjectPage
    UI --> User : Show edit page
    deactivate UI
end

note over User, FileSystem
  **Key Points:**
  1. **Validation first** (name, type, uniqueness)
  2. **Registry pattern** for polymorphic creation
  3. **Initialize-after-construction** (DI + runtime data)
  4. **Ports isolate Core** from infrastructure
  5. **EditProjectUseCase wraps** the created project
  6. **Navigation with ViewModel** (Shell parameters)
end note

@enduml
