<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TileTextureGenerator.Presentation.UI.ViewModels"
             xmlns:res="clr-namespace:TileTextureGenerator.Presentation.UI.Resources.Strings"
             xmlns:converters="clr-namespace:TileTextureGenerator.Presentation.UI.Converters"
             x:Class="TileTextureGenerator.Presentation.UI.Pages.CreateProjectPage"
             x:DataType="viewmodels:CreateProjectViewModel"
             Title="{x:Static res:AppResources.ProjectManagement_Title}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:BoolToButtonColorConverter x:Key="BoolToButtonColorConverter" />
            <converters:BoolToButtonTextColorConverter x:Key="BoolToButtonTextColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" BackgroundColor="#FFEBEE" Padding="10" CornerRadius="8">
                <Label Text="{Binding ErrorMessage}" TextColor="#C62828" FontSize="14" />
            </Frame>
            <Grid x:Name="ResponsiveGrid" ColumnSpacing="15" RowSpacing="15" SizeChanged="OnResponsiveGridSizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <VerticalStackLayout x:Name="NameStack" Grid.Row="0" Grid.Column="0" Spacing="8">
                    <Label Text="{x:Static res:AppResources.ProjectManagement_ProjectName}" FontSize="14" FontAttributes="Bold" />
                    <Entry Placeholder="{x:Static res:AppResources.ProjectManagement_ProjectName}" Text="{Binding ProjectName}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                </VerticalStackLayout>
                <!-- OtherStack is now a Grid instead of HorizontalStackLayout -->
                <Grid x:Name="OtherStack" Grid.Row="0" Grid.Column="1" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout x:Name="TypeStack" Grid.Column="0" Spacing="8">
                        <Label Text="{x:Static res:AppResources.ProjectManagement_ProjectType}" FontSize="14" FontAttributes="Bold" />
                        <Picker ItemsSource="{Binding ProjectTypes}" 
                                ItemDisplayBinding="{Binding LocalizedName}" 
                                SelectedItem="{Binding SelectedProjectTypeItem}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout x:Name="ButtonStack" Grid.Column="1" Spacing="8" VerticalOptions="End">
                        <Label Text=" " FontSize="14" />
                        <Button Text="➕" 
                                Command="{Binding CreateProjectCommand}" 
                                BackgroundColor="{Binding IsCreateButtonActive, Converter={StaticResource BoolToButtonColorConverter}}" 
                                TextColor="{Binding IsCreateButtonActive, Converter={StaticResource BoolToButtonTextColorConverter}}" 
                                WidthRequest="50" 
                                HeightRequest="50" 
                                CornerRadius="25" 
                                FontSize="24" 
                                Padding="0" />
                    </VerticalStackLayout>
                </Grid>
            </Grid>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#512BD4" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
