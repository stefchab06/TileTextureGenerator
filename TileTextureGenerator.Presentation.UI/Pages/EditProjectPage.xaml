<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TileTextureGenerator.Presentation.UI.ViewModels"
             xmlns:res="clr-namespace:TileTextureGenerator.Presentation.UI.Resources.Strings"
             xmlns:converters="clr-namespace:TileTextureGenerator.Presentation.UI.Converters"
             xmlns:selectors="clr-namespace:TileTextureGenerator.Presentation.UI.Selectors"
             xmlns:templates="clr-namespace:TileTextureGenerator.Presentation.UI.Templates"
             xmlns:controls="clr-namespace:TileTextureGenerator.Presentation.UI.Controls"
             x:Class="TileTextureGenerator.Presentation.UI.Pages.EditProjectPage"
             x:DataType="vm:EditProjectViewModel"
             Shell.NavBarIsVisible="True"
             Title="{Binding ShellTitle}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToButtonColorConverter x:Key="BoolToButtonColorConverter" />
            <converters:BoolToButtonTextColorConverter x:Key="BoolToButtonTextColorConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <!-- Project Template Selector -->
            <selectors:ProjectTemplateSelector x:Key="ProjectTemplateSelector">
                <selectors:ProjectTemplateSelector.FloorTileTemplate>
                    <DataTemplate>
                        <templates:FloorTileTemplate />
                    </DataTemplate>
                </selectors:ProjectTemplateSelector.FloorTileTemplate>
            </selectors:ProjectTemplateSelector>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Toolbar with Close button -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{x:Static res:AppResources.EditProject_Close}"
                     Clicked="OnCloseClicked" 
                     Order="Primary" 
                     Priority="0" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Project properties (dynamic template selection with automatic placeholder fallback) -->
            <Frame BorderColor="{StaticResource Primary}"
                   BackgroundColor="{StaticResource Secondary}"
                   Padding="10">

                <!-- TemplatedContentView automatically displays PlaceholderTemplate if no specific template exists -->
                <controls:TemplatedContentView TemplateSelector="{StaticResource ProjectTemplateSelector}"
                                               TypeName="{Binding ConcreteTypeName}"
                                               TemplateData="{Binding ProjectViewModel}" />
            </Frame>

            <!-- Save button (full width) -->
            <Button Text="{x:Static res:AppResources.EditProject_Save}"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    HeightRequest="50"
                    FontSize="Medium"
                    FontAttributes="Bold" />

            <!-- Add Transformation section -->
            <Frame BorderColor="{StaticResource Gray300}"
                   Padding="10">
                <VerticalStackLayout Spacing="10">

                    <!-- Collapsible Transformation Picker -->
                    <VerticalStackLayout Spacing="0">
                        <!-- Header + Add Button (Grid layout like ManageProjectListPage) -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Header (expandable picker) -->
                            <VerticalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="{x:Static res:AppResources.EditProject_TransformationType}" FontSize="14" FontAttributes="Bold" />
                                <Frame BorderColor="{StaticResource Gray300}"
                                       Padding="10"
                                       CornerRadius="8"
                                       HasShadow="False"
                                       BackgroundColor="{StaticResource Secondary}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleTransformationPickerCommand}" />
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- Preview image (if selected) -->
                                        <Image Grid.Column="0"
                                               Source="{Binding SelectedTransformationType.Icon, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                               WidthRequest="40"
                                               HeightRequest="40"
                                               Aspect="AspectFit"
                                               Margin="0,0,10,0"
                                               IsVisible="{Binding SelectedTransformationType, Converter={StaticResource IsNotNullConverter}}" />

                                        <!-- Label -->
                                        <Label Grid.Column="1"
                                               Text="{Binding SelectedTransformationType.LocalizedName, FallbackValue={x:Static res:AppResources.EditProject_SelectTransformationType}}"
                                               VerticalOptions="Center"
                                               FontSize="Body" />

                                        <!-- Arrow icon (▼ when collapsed, ▲ when expanded) -->
                                        <Label Grid.Column="2"
                                               Text="{Binding IsTransformationPickerExpanded, Converter={StaticResource BoolToTextConverter}, ConverterParameter='▲|▼'}"
                                               VerticalOptions="Center"
                                               FontSize="Large"
                                               Margin="10,0,0,0" />
                                    </Grid>
                                </Frame>
                            </VerticalStackLayout>

                            <!-- Add button (always visible, color changes based on selection) -->
                            <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="End">
                                <Label Text=" " FontSize="14" />
                                <Button Text="+"
                                        Command="{Binding AddTransformationCommand}"
                                        BackgroundColor="{Binding IsAddButtonActive, Converter={StaticResource BoolToButtonColorConverter}}"
                                        TextColor="{Binding IsAddButtonActive, Converter={StaticResource BoolToButtonTextColorConverter}}"
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        CornerRadius="25"
                                        FontSize="24"
                                        Padding="0" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Dropdown list (visible when expanded) -->
                        <CollectionView ItemsSource="{Binding AvailableTransformationTypes}"
                                        SelectionMode="None"
                                        IsVisible="{Binding IsTransformationPickerExpanded}"
                                        HeightRequest="{Binding AvailableTransformationTypes.Count, Converter={StaticResource CountToHeightConverter}}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:TransformationTypeItem">
                                    <Frame BorderColor="{StaticResource Gray200}"
                                           Padding="10"
                                           Margin="0,2"
                                           CornerRadius="4"
                                           HasShadow="False"
                                           BackgroundColor="White">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditProjectViewModel}}, Path=SelectTransformationTypeCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Frame.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Image Grid.Column="0"
                                                   Source="{Binding Icon, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                                   WidthRequest="50"
                                                   HeightRequest="50"
                                                   Aspect="AspectFit"
                                                   Margin="0,0,10,0" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding LocalizedName}"
                                                   VerticalOptions="Center"
                                                   FontSize="Body" />
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <CollectionView x:Name="TransformationsCollectionView"
                            ItemsSource="{Binding Transformations}"
                            Margin="0,20,0,0"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                        Span="1"
                                        HorizontalItemSpacing="10"
                                        VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TransformationCardItem">

                        <Border Stroke="#BDBDBD" StrokeThickness="2" StrokeShape="RoundRectangle 16" Margin="8" Padding="12" BackgroundColor="{AppThemeBinding Light=White, Dark=#222}">
                            <VerticalStackLayout Spacing="8">
                                <!-- Transformation type -->
                                <Label Text="{Binding LocalizedName}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />

                                <!-- Transformation Icon -->
                                <Frame Padding="0" CornerRadius="8" HeightRequest="128" HorizontalOptions="Center">
                                    <Image Source="{Binding IconSource}" HeightRequest="128" Aspect="AspectFit" />
                                </Frame>

                                <!-- Action Buttons (left and right) -->
                                <Grid Grid.Row="2" ColumnSpacing="0" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Open button (left) -->
                                    <Button Grid.Column="0"
                                            Text="📂"
                                            WidthRequest="50"
                                            HeightRequest="50"
                                            CornerRadius="25"
                                            BackgroundColor="{StaticResource Gray400}"
                                            TextColor="White"
                                            FontSize="24"
                                            Margin="8,0,0,0"
                                            IsEnabled="False" />

                                    <!-- Delete button (right) -->
                                    <Button Grid.Column="2"
                                            Text="🗑️"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditProjectViewModel}}, Path=RemoveTransformationCommand}"
                                            CommandParameter="{Binding Id}"
                                            WidthRequest="50"
                                            HeightRequest="50"
                                            CornerRadius="25"
                                            BackgroundColor="{StaticResource Tertiary}"
                                            TextColor="White"
                                            FontSize="24"
                                            Margin="0,0,8,0" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
