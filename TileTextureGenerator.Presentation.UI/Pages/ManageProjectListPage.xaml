<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TileTextureGenerator.Presentation.UI.ViewModels"
             xmlns:res="clr-namespace:TileTextureGenerator.Presentation.UI.Resources.Strings"
             xmlns:converters="clr-namespace:TileTextureGenerator.Presentation.UI.Converters"
             xmlns:services="clr-namespace:TileTextureGenerator.Presentation.UI.Services"
             x:Class="TileTextureGenerator.Presentation.UI.Pages.ManageProjectListPage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:BoolToButtonColorConverter x:Key="BoolToButtonColorConverter" />
            <converters:BoolToButtonTextColorConverter x:Key="BoolToButtonTextColorConverter" />
            <services:ProjectTypeLocalizer x:Key="ProjectTypeLocalizer" />
            <converters:ProjectTypeToLocalizedNameConverter x:Key="ProjectTypeToLocalizedNameConverter" Localizer="{StaticResource ProjectTypeLocalizer}" />
            <converters:ProjectStatusToLocalizedStringConverter x:Key="ProjectStatusToLocalizedStringConverter" Localizer="{StaticResource ProjectTypeLocalizer}" />
            <converters:ProjectImageOrPlaceholderConverter x:Key="ProjectImageOrPlaceholderConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout Padding="20,10,20,20" Spacing="20">
            
            <!-- Custom Header with centered title and right-aligned language button -->
            <Grid ColumnSpacing="10" HeightRequest="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Static Page Title (not localized in real-time) -->
                <Label Grid.Column="0" 
                       Text="{x:Static res:AppResources.ProjectManagement_Title}" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center" 
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <!-- Language Toggle Button -->
                <Button Grid.Column="1"
                        ImageSource="{Binding CurrentLanguageFlag}"
                        Command="{Binding CycleLanguageCommand}"
                        BackgroundColor="Transparent"
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center"
                        Padding="0" />
            </Grid>
            <Frame IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" BackgroundColor="#FFEBEE" Padding="10" CornerRadius="8">
                <Label Text="{Binding ErrorMessage}" TextColor="#C62828" FontSize="14" />
            </Frame>
            <Grid x:Name="ResponsiveGrid" ColumnSpacing="15" RowSpacing="15" SizeChanged="OnResponsiveGridSizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <VerticalStackLayout x:Name="NameStack" Grid.Row="0" Grid.Column="0" Spacing="8">
                    <Label Text="{x:Static res:AppResources.ProjectManagement_ProjectName}" FontSize="14" FontAttributes="Bold" />
                    <Entry Placeholder="{x:Static res:AppResources.ProjectManagement_ProjectName}" Text="{Binding ProjectName}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                </VerticalStackLayout>
                <!-- OtherStack is now a Grid instead of HorizontalStackLayout -->
                <Grid x:Name="OtherStack" Grid.Row="0" Grid.Column="1" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout x:Name="TypeStack" Grid.Column="0" Spacing="8">
                        <Label Text="{x:Static res:AppResources.ProjectManagement_ProjectType}" FontSize="14" FontAttributes="Bold" />
                        <Picker ItemsSource="{Binding ProjectTypes}" 
                                ItemDisplayBinding="{Binding LocalizedName}" 
                                SelectedItem="{Binding SelectedProjectTypeItem}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout x:Name="ButtonStack" Grid.Column="1" Spacing="8" VerticalOptions="End">
                        <Label Text=" " FontSize="14" />
                        <Button Text="➕" 
                                Command="{Binding CreateProjectCommand}" 
                                BackgroundColor="{Binding IsCreateButtonActive, Converter={StaticResource BoolToButtonColorConverter}}" 
                                TextColor="{Binding IsCreateButtonActive, Converter={StaticResource BoolToButtonTextColorConverter}}" 
                                WidthRequest="50" 
                                HeightRequest="50" 
                                CornerRadius="25" 
                                FontSize="24" 
                                Padding="0" />
                    </VerticalStackLayout>
                </Grid>
            </Grid>
            <!-- Project List -->
            <CollectionView x:Name="ProjectsCollectionView"
                ItemsSource="{Binding Projects}"
                Margin="0,20,0,0"
                SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#BDBDBD" StrokeThickness="2" StrokeShape="RoundRectangle 16" Margin="8" Padding="12" BackgroundColor="{AppThemeBinding Light=White, Dark=#222}">
                            <VerticalStackLayout Spacing="8">
                                <!-- Project Name -->
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
                                <!-- Type (left) + Status (right) -->
                                <Grid ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Text="{Binding Type}" FontSize="14" HorizontalOptions="Start" />
                                    <Label Grid.Column="1" Text="{Binding Status}" FontSize="14" HorizontalOptions="End" />
                                </Grid>
                                <!-- Project Image -->
                                <Frame Padding="0" CornerRadius="8" HeightRequest="128" HorizontalOptions="Center">
                                    <Image Source="{Binding DisplayImage}" HeightRequest="128" Aspect="AspectFit" />
                                </Frame>
                                <!-- Action Buttons (Grid for margins + FlexLayout for centering) -->
                                <Grid ColumnSpacing="0" Padding="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <FlexLayout Grid.Column="1"
                                                JustifyContent="Center" 
                                                AlignItems="Center" 
                                                Wrap="NoWrap" 
                                                Direction="Row">

                                        <Button Text="📂" 
                                                BackgroundColor="#E3F2FD" 
                                                CornerRadius="20" 
                                                HeightRequest="40" 
                                                WidthRequest="40" 
                                                FontSize="20"
                                                Margin="6,0"
                                                IsVisible="{Binding CanLoad}"
                                                Command="{Binding BindingContext.LoadProjectCommand, Source={x:Reference ProjectsCollectionView}}"
                                                CommandParameter="{Binding .}" />

                                        <Button Text="📄" 
                                                BackgroundColor="#E8F5E9" 
                                                CornerRadius="20" 
                                                HeightRequest="40" 
                                                WidthRequest="40" 
                                                FontSize="20"
                                                Margin="6,0"
                                                IsVisible="{Binding CanGenerate}"
                                                Command="{Binding BindingContext.GeneratePdfCommand, Source={x:Reference ProjectsCollectionView}}"
                                                CommandParameter="{Binding .}" />

                                        <Button Text="🗄️" 
                                                BackgroundColor="#FFF3E0" 
                                                CornerRadius="20" 
                                                HeightRequest="40" 
                                                WidthRequest="40" 
                                                FontSize="20"
                                                Margin="6,0"
                                                IsVisible="{Binding CanArchive}"
                                                Command="{Binding BindingContext.ArchiveProjectCommand, Source={x:Reference ProjectsCollectionView}}"
                                                CommandParameter="{Binding .}" />

                                        <Button Text="🗑️" 
                                                BackgroundColor="#FFEBEE" 
                                                CornerRadius="20" 
                                                HeightRequest="40" 
                                                WidthRequest="40" 
                                                FontSize="20"
                                                Margin="6,0"
                                                IsVisible="{Binding CanDelete}"
                                                Command="{Binding BindingContext.DeleteProjectCommand, Source={x:Reference ProjectsCollectionView}}"
                                                CommandParameter="{Binding .}" />
                                    </FlexLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#512BD4" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
