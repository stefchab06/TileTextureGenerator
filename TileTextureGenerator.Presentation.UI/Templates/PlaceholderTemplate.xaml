<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:TileTextureGenerator.Presentation.UI.Resources.Strings"
             x:Class="TileTextureGenerator.Presentation.UI.Templates.PlaceholderTemplate">

    <VerticalStackLayout Spacing="20" Padding="20">
        <Label Text="⚠️"
               FontSize="48"
               HorizontalOptions="Center" />
        
        <Label Text="Project properties not yet implemented"
               FontSize="16"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />
        
        <Label Text="This project type does not have a template yet. Properties will be available in a future iteration."
               HorizontalTextAlignment="Center"
               FontSize="Small"
               TextColor="{StaticResource Gray600}" />
    </VerticalStackLayout>
</ContentView>
