@startuml Load Project - Sequence Diagram

title Load Project Use Case - Complete Flow

actor User
participant "ManageProjectList\nPage" as UI
participant "ManageProjectList\nViewModel" as ViewModel
participant "ManageProjectList\nUseCase" as UseCase
participant "IProjectsManager\n(Port Input)" as ManagerPort
participant "ProjectsManager\n(Service)" as Manager
participant "IProjectsStore\n(Port Output)" as StorePort
participant "JsonProjectsStore\n(Adapter)" as Store
participant "JSonProjectStore\n(Adapter)" as ProjectStore
participant "FileSystem\nService" as FileSystem
participant "TransformationType\nRegistry" as TransformRegistry
participant "ProjectBase\n(Entity)" as Project

User -> UI : Click "Load" on project card
activate UI
UI -> ViewModel : OnLoadProjectAsync(project)
activate ViewModel

ViewModel -> UseCase : LoadProjectAsync(projectName)
activate UseCase

' Validation
UseCase -> UseCase : Validate projectName
alt Validation fails
    UseCase --> ViewModel : LoadProjectResult.ValidationError
    ViewModel --> UI : Show error message
    UI --> User : Display error
else Validation succeeds
    
    ' Load project
    UseCase -> ManagerPort : SelectProjectAsync(projectName)
    activate ManagerPort
    ManagerPort -> Manager : SelectProjectAsync(projectName)
    activate Manager
    
    Manager -> StorePort : LoadAsync(projectName)
    activate StorePort
    StorePort -> Store : LoadAsync(projectName)
    activate Store
    
    Store -> Store : Resolve project directory path
    Store -> FileSystem : File.Exists(project.json)
    
    alt Project doesn't exist
        Store --> StorePort : null
        StorePort --> Manager : null
        Manager -> Manager : throw InvalidOperationException
        Manager --> ManagerPort : exception
        ManagerPort --> UseCase : exception
        UseCase --> ViewModel : LoadProjectResult.Error
        ViewModel --> UI : Show error
        UI --> User : Display error
    else Project exists
        
        Store -> FileSystem : ReadAllTextAsync(project.json)
        FileSystem --> Store : JSON content
        
        Store -> Store : Parse JSON\n(get "Type" property)
        Store -> TransformRegistry : GetTypeByName(type)
        activate TransformRegistry
        TransformRegistry --> Store : Type
        deactivate TransformRegistry
        
        Store -> Store : _factory(Type)
        create Project
        Store -> Project : new (via DI factory)
        
        Store -> Store : Deserialize properties from JSON
        Store -> Project : Set Name, Status, LastModifiedDate, etc.
        
        alt DisplayImage path exists
            Store -> FileSystem : ReadAllBytesAsync(displayImage path)
            FileSystem --> Store : image bytes
            Store -> Project : Set DisplayImage
        end
        
        alt SourceImage path exists
            Store -> FileSystem : ReadAllBytesAsync(sourceImage path)
            FileSystem --> Store : image bytes
            Store -> Project : Set SourceImage
        end
        
        Store -> Project : Initialize(name)
        activate Project
        Project -> Project : Validate name
        Project -> Project : Calculate AvailableActions
        deactivate Project
        
        Store --> StorePort : ProjectBase instance
        deactivate Store
        StorePort --> Manager : ProjectBase
        deactivate StorePort
        
        Manager --> ManagerPort : ProjectBase
        deactivate Manager
        ManagerPort --> UseCase : ProjectBase
        deactivate ManagerPort
        
        ' Create EditProjectUseCase
        UseCase -> UseCase : new EditProjectUseCase(project)
        UseCase --> ViewModel : LoadProjectResult.Success\n(project, editUseCase)
        deactivate UseCase
        
        ' Navigate to EditProjectPage
        ViewModel -> ViewModel : new EditProjectViewModel(editUseCase)
        ViewModel -> UI : Shell.GoToAsync("EditProjectPage",\nviewModel)
        deactivate ViewModel
        
        UI -> UI : Navigate to EditProjectPage
        UI --> User : Show edit page with\nloaded project data
        deactivate UI
    end
end

note over User, FileSystem
  **Key Differences from CreateProject:**
  1. **Loads from JSON** instead of creating new
  2. **Registry used for polymorphic deserialization**
  3. **Images loaded from disk** (if paths exist)
  4. **Transformations list** loaded (if present)
  5. **Same EditProjectUseCase** as CreateProject (reusable!)
end note

note over Project
  **Loaded Project State:**
  - Name, Type, Status from JSON
  - DisplayImage, SourceImage from files
  - Transformations list (DTOs)
  - AvailableActions calculated
  - Ready for editing
end note

@enduml
